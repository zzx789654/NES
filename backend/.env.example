# ── 資料庫 ────────────────────────────────────────────────────────────────────
# PostgreSQL（生產環境）
DATABASE_URL=postgresql://secvision:changeme@localhost:5432/secvision
# SQLite（本機開發，無需安裝 PostgreSQL）
# DATABASE_URL=sqlite:///./secvision.db

# ── 安全金鑰 ──────────────────────────────────────────────────────────────────
# 建議以 `openssl rand -hex 32` 產生，切勿使用預設值
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# ── JWT Token ────────────────────────────────────────────────────────────────
# Token 有效期限（分鐘），預設 8 小時
ACCESS_TOKEN_EXPIRE_MINUTES=480
# JWT 簽章演算法
ALGORITHM=HS256

# ── CORS ─────────────────────────────────────────────────────────────────────
# 允許的前端來源（逗號分隔），留空則套用 main.py 的預設值
# 生產環境請指定實際網域，避免使用萬用字元
ALLOWED_ORIGINS=http://localhost,http://127.0.0.1
