# SecVision ISMS Portal — 環境變數範本
# 複製此檔為 backend/.env 並填入實際值後再啟動服務
# 警告：.env 含敏感資訊，切勿提交至版本控制

# ── 資料庫 ────────────────────────────────────────────────
# 開發：SQLite（無需外部服務）
DATABASE_URL=sqlite:///./secvision.db

# 正式環境：PostgreSQL
# DATABASE_URL=postgresql+psycopg2://secvision:<密碼>@127.0.0.1:5432/secvision

# ── JWT 驗證 ──────────────────────────────────────────────
# 必填：強隨機值，至少 32 bytes。建立指令：openssl rand -hex 32
SECRET_KEY=<請替換為 openssl rand -hex 32 產生的強密鑰>

# Token 有效期（分鐘），預設 480 = 8 小時
ACCESS_TOKEN_EXPIRE_MINUTES=480

# JWT 簽名演算法，請勿更改
ALGORITHM=HS256

# ── CORS ─────────────────────────────────────────────────
# 開發：不設定（預設 *，允許所有來源）
# 正式環境：以逗號分隔，明確列出前端網域
# ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com
